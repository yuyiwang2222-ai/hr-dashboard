# Cloudflare R2 設定
# 到 Cloudflare Dashboard > R2 > Manage R2 API Tokens 取得

# R2 帳號 ID，可在 Cloudflare Dashboard 首頁查看
R2_ACCOUNT_ID=your_account_id_here

# R2 API Token，建立時權限至少要有 Edit
R2_ACCESS_KEY_ID=your_access_key_here
R2_SECRET_ACCESS_KEY=your_secret_key_here

# R2 Bucket 名稱
R2_BUCKET_NAME=hr-reports

# R2 公開網址，可用 Custom Domain 或 Public Bucket 網址
R2_PUBLIC_DOMAIN=your-bucket.your-domain.com

# ============================================
# Streamlit Cloud 可改放到 secrets
# 到 Streamlit Cloud > App Settings > Secrets 設定
# ============================================
# [r2]
# account_id = "your_account_id"
# access_key_id = "your_access_key"
# secret_access_key = "your_secret_key"
# bucket_name = "hr-reports"
# public_domain = "your-bucket.your-domain.com"

